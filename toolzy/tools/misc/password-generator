<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0"/>
<title>Password Generator — Toolzy</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@700;800&family=DM+Sans:wght@300;400;500&family=Share+Tech+Mono&display=swap" rel="stylesheet"/>
<style>
:root{--bg:#07080f;--card:#111422;--border:#1c1f35;--a1:#00e5ff;--a5:#a78bfa;--a2:#ff3cac;--a4:#43e97b;--a3:#f5a623;--text:#dde2ff;--muted:#4a5070;--muted2:#6a7090;--fh:'Syne',sans-serif;--fb:'DM Sans',sans-serif;--fm:'Share Tech Mono',monospace;}
*{margin:0;padding:0;box-sizing:border-box;}
body{background:var(--bg);color:var(--text);font-family:var(--fb);min-height:100vh;overflow-x:hidden;}
body::before{content:'';position:fixed;inset:0;background-image:linear-gradient(rgba(0,229,255,.025) 1px,transparent 1px),linear-gradient(90deg,rgba(0,229,255,.025) 1px,transparent 1px);background-size:56px 56px;pointer-events:none;z-index:0;}
.blob{position:fixed;border-radius:50%;filter:blur(130px);pointer-events:none;z-index:0;}
.b1{width:500px;height:500px;background:#a78bfa;opacity:.06;top:-150px;right:-150px;animation:bd 14s ease-in-out infinite alternate;}
.b2{width:400px;height:400px;background:#00e5ff;opacity:.06;bottom:-100px;left:-100px;animation:bd 18s ease-in-out infinite alternate-reverse;}
@keyframes bd{from{transform:translate(0,0) scale(1);}to{transform:translate(40px,30px) scale(1.1);}}
nav{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;padding:0 32px;height:62px;background:rgba(7,8,15,.9);backdrop-filter:blur(20px);border-bottom:1px solid var(--border);}
.nav-logo{font-family:var(--fh);font-size:1.3rem;font-weight:800;letter-spacing:-1px;background:linear-gradient(120deg,#00e5ff,#a78bfa);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;text-decoration:none;}
.btn-back{background:transparent;border:1px solid var(--border);color:var(--muted2);font-family:var(--fb);font-size:.82rem;padding:8px 18px;border-radius:100px;cursor:pointer;text-decoration:none;transition:all .2s;display:inline-flex;align-items:center;gap:6px;}
.btn-back:hover{border-color:var(--a1);color:var(--a1);}
main{position:relative;z-index:1;max-width:620px;margin:0 auto;padding:48px 24px 100px;}
.tool-header{text-align:center;margin-bottom:40px;}
.tool-icon{width:72px;height:72px;border-radius:20px;background:linear-gradient(135deg,#a78bfa15,#00e5ff15);border:1px solid #a78bfa30;display:flex;align-items:center;justify-content:center;font-size:2rem;margin:0 auto 16px;animation:iconpulse 3s ease-in-out infinite;}
@keyframes iconpulse{0%,100%{box-shadow:0 0 0 0 #a78bfa20;}50%{box-shadow:0 0 0 16px #a78bfa00;}}
.tool-title{font-family:var(--fh);font-size:2rem;font-weight:800;letter-spacing:-1px;background:linear-gradient(135deg,#a78bfa,#00e5ff);-webkit-background-clip:text;background-clip:text;-webkit-text-fill-color:transparent;}
.tool-sub{color:var(--muted2);font-size:.9rem;margin-top:6px;}
.card{background:var(--card);border:1px solid var(--border);border-radius:20px;padding:28px;margin-bottom:16px;}
.pwd-display{background:#0a0b14;border:1px solid var(--border);border-radius:14px;padding:20px;margin-bottom:16px;position:relative;min-height:72px;display:flex;align-items:center;}
.pwd-text{font-family:var(--fm);font-size:1.05rem;color:var(--text);word-break:break-all;flex:1;line-height:1.6;letter-spacing:.04em;}
.pwd-text .c-upper{color:#00e5ff;}
.pwd-text .c-lower{color:#dde2ff;}
.pwd-text .c-num{color:#43e97b;}
.pwd-text .c-sym{color:#ff3cac;}
.copy-btn{position:absolute;top:12px;right:12px;background:#ffffff08;border:1px solid var(--border);color:var(--muted2);padding:6px 12px;border-radius:8px;cursor:pointer;font-size:.75rem;transition:all .2s;font-family:var(--fb);}
.copy-btn:hover{border-color:var(--a1);color:var(--a1);}
.strength-bar-wrap{margin-bottom:20px;}
.strength-label{display:flex;justify-content:space-between;font-size:.75rem;margin-bottom:6px;}
.strength-bar{height:6px;background:#ffffff08;border-radius:100px;overflow:hidden;}
.strength-fill{height:100%;border-radius:100px;transition:width .4s,background .4s;}
.strength-text{font-weight:600;}
.range-row{display:flex;align-items:center;gap:12px;margin-bottom:20px;}
.range-row label{font-size:.78rem;color:var(--muted2);white-space:nowrap;min-width:80px;}
.range-row input[type=range]{flex:1;accent-color:var(--a5);}
.range-val{font-family:var(--fm);font-size:.9rem;color:var(--a5);min-width:28px;text-align:right;}
.toggles{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px;}
.toggle{display:flex;align-items:center;gap:10px;background:#ffffff04;border:1px solid var(--border);border-radius:12px;padding:12px 14px;cursor:pointer;transition:all .2s;user-select:none;}
.toggle:hover{border-color:var(--a5);background:#a78bfa08;}
.toggle.active{border-color:#a78bfa50;background:#a78bfa10;}
.toggle-check{width:18px;height:18px;border-radius:5px;border:1.5px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:.7rem;transition:all .2s;flex-shrink:0;}
.toggle.active .toggle-check{background:var(--a5);border-color:var(--a5);color:#fff;}
.toggle-label{font-size:.82rem;color:var(--muted2);}
.toggle.active .toggle-label{color:var(--text);}
.gen-btn{width:100%;padding:14px;background:linear-gradient(135deg,#a78bfa,#00e5ff);border:none;border-radius:100px;color:#07080f;font-family:var(--fh);font-size:.9rem;font-weight:700;cursor:pointer;transition:opacity .2s,transform .1s;}
.gen-btn:hover{opacity:.85;}
.gen-btn:active{transform:scale(.98);}
.bulk-grid{display:grid;gap:8px;margin-top:4px;}
.bulk-item{display:flex;align-items:center;justify-content:space-between;background:#0a0b14;border:1px solid var(--border);border-radius:10px;padding:10px 14px;}
.bulk-pwd{font-family:var(--fm);font-size:.82rem;color:var(--text);flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;}
.bulk-copy{background:transparent;border:none;color:var(--muted2);cursor:pointer;font-size:.8rem;padding:2px 8px;border-radius:6px;transition:color .2s;}
.bulk-copy:hover{color:var(--a1);}
.sec-title{font-family:var(--fh);font-size:.78rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;color:var(--muted2);margin-bottom:14px;}
</style>
</head>
<body>
<div class="blob b1"></div><div class="blob b2"></div>
<nav>
  <a href="../../index.html" class="btn-back">← Back to Toolzy</a>
  <a href="../../index.html" class="nav-logo">Toolzy</a>
</nav>
<main>
  <div class="tool-header">
    <div class="tool-icon">🔑</div>
    <div class="tool-title">Password Generator</div>
    <div class="tool-sub">Generate strong, secure passwords instantly</div>
  </div>
  <div class="card">
    <div class="pwd-display">
      <div class="pwd-text" id="pwdText">Click Generate</div>
      <button class="copy-btn" onclick="copyPwd()" id="copyBtn">Copy</button>
    </div>
    <div class="strength-bar-wrap">
      <div class="strength-label">
        <span style="color:var(--muted2)">Strength</span>
        <span class="strength-text" id="strengthText">—</span>
      </div>
      <div class="strength-bar"><div class="strength-fill" id="strengthFill" style="width:0%"></div></div>
    </div>
    <div class="range-row">
      <label>Length</label>
      <input type="range" id="lengthRange" min="4" max="64" value="16" oninput="updateLength();generate()"/>
      <span class="range-val" id="lengthVal">16</span>
    </div>
    <div class="toggles">
      <div class="toggle active" id="t-upper" onclick="toggleOpt(this)">
        <div class="toggle-check">✓</div>
        <span class="toggle-label">Uppercase (A–Z)</span>
      </div>
      <div class="toggle active" id="t-lower" onclick="toggleOpt(this)">
        <div class="toggle-check">✓</div>
        <span class="toggle-label">Lowercase (a–z)</span>
      </div>
      <div class="toggle active" id="t-num" onclick="toggleOpt(this)">
        <div class="toggle-check">✓</div>
        <span class="toggle-label">Numbers (0–9)</span>
      </div>
      <div class="toggle active" id="t-sym" onclick="toggleOpt(this)">
        <div class="toggle-check">✓</div>
        <span class="toggle-label">Symbols (!@#$)</span>
      </div>
      <div class="toggle" id="t-noamb" onclick="toggleOpt(this)">
        <div class="toggle-check"></div>
        <span class="toggle-label">No ambiguous (0,O,l,1)</span>
      </div>
      <div class="toggle" id="t-pro" onclick="toggleOpt(this)">
        <div class="toggle-check"></div>
        <span class="toggle-label">Pronounceable</span>
      </div>
    </div>
    <button class="gen-btn" onclick="generate()">🔄 Generate New Password</button>
  </div>
  <div class="card">
    <div class="sec-title">Bulk Generate (5 passwords)</div>
    <div class="bulk-grid" id="bulkGrid"></div>
    <button class="gen-btn" style="margin-top:14px;background:linear-gradient(135deg,#1c1f35,#252840);color:var(--text);" onclick="generateBulk()">Generate 5 More</button>
  </div>
</main>
<script>
const UPPER='ABCDEFGHIJKLMNOPQRSTUVWXYZ';
const LOWER='abcdefghijklmnopqrstuvwxyz';
const NUMS='0123456789';
const SYMS='!@#$%^&*()_+-=[]{}|;:,.<>?';
const VOWELS='aeiou';
const CONSONANTS='bcdfghjklmnpqrstvwxyz';

function isActive(id){ return document.getElementById(id).classList.contains('active'); }
function updateLength(){ document.getElementById('lengthVal').textContent = document.getElementById('lengthRange').value; }

function generatePwd(len){
  // --- FIX 1: Pronounceable mode rewritten cleanly (removed broken `const arr=[...VOWELS],[...CONSONANTS]` SyntaxError) ---
  if(isActive('t-pro')){
    let pwd = '';
    for(let i = 0; i < len; i++){
      // Alternate consonant / vowel for pronounceability
      const pool = (i % 2 === 0) ? CONSONANTS : VOWELS;
      pwd += pool[Math.floor(Math.random() * pool.length)];
    }
    return pwd;
  }

  let chars = '';
  if(isActive('t-upper')) chars += UPPER;
  if(isActive('t-lower')) chars += LOWER;
  if(isActive('t-num'))   chars += NUMS;
  if(isActive('t-sym'))   chars += SYMS;
  if(!chars) chars = LOWER; // fallback: always produce something

  if(isActive('t-noamb')) chars = chars.replace(/[0O1lI]/g, '');
  if(!chars) chars = 'abcdefghjkmnpqrstuvwxyz'; // fallback after ambiguous removal

  const arr = new Uint32Array(len);
  crypto.getRandomValues(arr);
  return Array.from(arr, v => chars[v % chars.length]).join('');
}

function colorize(pwd){
  return pwd.split('').map(c => {
    if(/[A-Z]/.test(c)) return `<span class="c-upper">${c}</span>`;
    if(/[a-z]/.test(c)) return `<span class="c-lower">${c}</span>`;
    if(/[0-9]/.test(c)) return `<span class="c-num">${c}</span>`;
    return `<span class="c-sym">${escHtml(c)}</span>`;
  }).join('');
}

// --- FIX 2: Helper to escape HTML special chars (prevents display glitches for < > & in symbols) ---
function escHtml(c){
  return c.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function calcStrength(pwd){
  let score = 0;
  if(pwd.length >= 8)  score++;
  if(pwd.length >= 12) score++;
  if(pwd.length >= 16) score++;
  if(/[A-Z]/.test(pwd)) score++;
  if(/[a-z]/.test(pwd)) score++;
  if(/[0-9]/.test(pwd)) score++;
  if(/[^A-Za-z0-9]/.test(pwd)) score++;
  const levels = [
    {w:14, label:'Very Weak',    color:'#ff3cac'},
    {w:28, label:'Weak',         color:'#ff6b35'},
    {w:50, label:'Fair',         color:'#f5a623'},
    {w:72, label:'Strong',       color:'#43e97b'},
    {w:100,label:'Very Strong',  color:'#00e5ff'}
  ];
  const idx = Math.min(Math.floor(score / 7 * 5), 4);
  return levels[idx];
}

let currentPwd = '';
function generate(){
  const len = parseInt(document.getElementById('lengthRange').value);
  currentPwd = generatePwd(len);
  document.getElementById('pwdText').innerHTML = colorize(currentPwd);
  const s = calcStrength(currentPwd);
  document.getElementById('strengthFill').style.cssText = `width:${s.w}%;background:${s.color};`;
  document.getElementById('strengthText').style.color = s.color;
  document.getElementById('strengthText').textContent = s.label;
  document.getElementById('copyBtn').textContent = 'Copy';
}

function copyPwd(){
  navigator.clipboard.writeText(currentPwd).then(() => {
    document.getElementById('copyBtn').textContent = '✓ Copied!';
    setTimeout(() => document.getElementById('copyBtn').textContent = 'Copy', 2000);
  });
}

function toggleOpt(el){
  el.classList.toggle('active');
  el.querySelector('.toggle-check').textContent = el.classList.contains('active') ? '✓' : '';
  generate();
}

function generateBulk(){
  const len = parseInt(document.getElementById('lengthRange').value);
  const grid = document.getElementById('bulkGrid');
  grid.innerHTML = '';

  for(let i = 0; i < 5; i++){
    const p = generatePwd(len);
    const div = document.createElement('div');
    div.className = 'bulk-item';

    const pwdSpan = document.createElement('span');
    pwdSpan.className = 'bulk-pwd';
    pwdSpan.textContent = p; // FIX 3: use textContent, not innerHTML, so quotes/symbols never break the DOM

    const btn = document.createElement('button');
    btn.className = 'bulk-copy';
    btn.textContent = '📋';
    // FIX 4: attach event listener instead of inline onclick — no quoting issues with any password character
    btn.addEventListener('click', () => {
      navigator.clipboard.writeText(p).then(() => {
        btn.textContent = '✓';
        setTimeout(() => btn.textContent = '📋', 1500);
      });
    });

    div.appendChild(pwdSpan);
    div.appendChild(btn);
    grid.appendChild(div);
  }
}

generate();
generateBulk();
</script>
</body>
</html>
